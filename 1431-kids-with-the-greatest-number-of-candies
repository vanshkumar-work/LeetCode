class Solution {
public:
    vector<bool> kidsWithCandies(vector<int>& candies, int extraCandies) {
        int m =  0 ;
        int n = candies.size();
        for(int i = 0;  i<candies.size() ; i++){
            m = max(candies[i],m);
        }
        vector<bool> ans ;
        for(int t : candies){
            t = t+extraCandies ;
            if(t>=m){
                ans.push_back(true);
            }
            else ans.push_back(false);
        }
        return ans ;
        
    }
};
